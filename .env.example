# Partner Portal Authentication
# ----------------------------
# Set these in Vercel Environment Variables for production,
# or in .env.local for local development.

# Authorized partner email
PARTNER_EMAIL=partner@sableassents.com

# Bcrypt hash of the partner password (generate with: node scripts/generate-hash.js "YourPassword")
PARTNER_PASSWORD_HASH=

# JWT signing secret (use a long random string — at least 32 characters)
JWT_SECRET=

# Two-Factor Authentication
# Set to "true" to require a 2FA code on login
TOTP_ENABLED=false
# Static 2FA code (used when TOTP_ENABLED=true)
TOTP_STATIC_CODE=
